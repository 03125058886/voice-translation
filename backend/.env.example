# OpenAI (required)
OPENAI_API_KEY=sk-...

# TTS Provider: "openai" or "elevenlabs"
TTS_PROVIDER=openai

# ElevenLabs (optional — premium TTS)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Twilio (optional — for phone call integration)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WEBHOOK_BASE_URL=https://yourdomain.com

# Infrastructure
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/voice_translation

# Security
API_SECRET_KEY=change-me-to-a-random-secret

# App
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost"]
