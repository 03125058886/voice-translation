# ============================================================
# Voice Translation Platform — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- OpenAI (REQUIRED) ---
OPENAI_API_KEY=sk-proj-...

# --- TTS Provider ---
# "openai" uses OpenAI TTS (included with OPENAI_API_KEY)
# "elevenlabs" uses ElevenLabs for higher quality voice
TTS_PROVIDER=openai

# --- ElevenLabs (optional) ---
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Twilio (optional — for phone call integration) ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1...
TWILIO_WEBHOOK_BASE_URL=https://your-public-domain.com

# --- Infrastructure ---
REDIS_URL=redis://redis:6379
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/voice_translation

# --- Security ---
API_SECRET_KEY=change-this-to-a-random-256-bit-secret

# --- App ---
DEBUG=false
CORS_ORIGINS=["http://localhost:3000","http://localhost"]
